{
  "name": "@averyso/alpha",
  "version": "1.0.0",
  "description": "Node-only Avery SDK for TypeScript.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avery-so/alpha.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/avery-so/alpha/issues"
  },
  "homepage": "https://alpha.avery.so/",
  "keywords": [
    "x402",
    "agent",
    "ai",
    "payments",
    "payment",
    "sdk",
    "vercel-ai-sdk",
    "mastra",
    "evm",
    "solana"
  ],
  "author": "Avery",
  "maintainers": [
    "bestony"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.3",
    "@vitest/coverage-v8": "^3.2.4",
    "ai": "^6.0.199",
    "publint": "^0.3.21",
    "tsdown": "^0.22.2",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@scure/base": "^1.2.6",
    "@solana/kit": "^6.9.0",
    "@x402/core": "^2.14.0",
    "@x402/evm": "^2.14.0",
    "@x402/fetch": "^2.14.0",
    "@x402/svm": "^2.14.0",
    "viem": "^2.52.2"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  }
}
