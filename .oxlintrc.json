{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import", "promise"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "warn",
    "perf": "warn",
    "style": "warn"
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/.next/**",
    "**/.output/**",
    "**/coverage/**",
    "docs/.vitepress/cache/**",
    "docs/.vitepress/dist/**",
    "**/node_modules/**"
  ],
  "rules": {
    "no-eval": "error",
    "import/no-named-export": "off",
    "import/group-exports": "off",
    "sort-keys": "off",
    "sort-imports": "off",
    "no-magic-numbers": "off",
    "max-classes-per-file": "off",
    "prefer-destructuring": "off",
    "@typescript-eslint/parameter-properties": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts"],
      "rules": {
        "@typescript-eslint/no-non-null-assertion": "off",
        "init-declarations": "off",
        "max-lines-per-function": "off",
        "max-statements": "off",
        "unicorn/no-null": "off",
        "unicorn/no-useless-undefined": "off"
      }
    },
    {
      "files": ["**/*.config.ts", "**/*.config.js"],
      "rules": {
        "import/no-default-export": "off"
      }
    },
    {
      "files": ["packages/sdk/types/**/*.d.ts"],
      "rules": {
        "max-params": "off"
      }
    },
    {
      "files": [
        "example/nextjs-ai-x402-exa/**/*.ts",
        "example/nextjs-ai-x402-exa/**/*.tsx",
        "example/nextjs-ai-x402-base-sepolia-paid-content/**/*.ts",
        "example/nextjs-ai-x402-base-sepolia-paid-content/**/*.tsx",
        "example/nextjs-mastra-x402-exa/**/*.ts",
        "example/nextjs-mastra-x402-exa/**/*.tsx",
        "example/tanstack-start-ai-x402-exa/**/*.ts",
        "example/tanstack-start-ai-x402-exa/**/*.tsx",
        "example/tanstack-start-mastra-x402-exa/**/*.ts",
        "example/tanstack-start-mastra-x402-exa/**/*.tsx"
      ],
      "rules": {
        "func-style": "off",
        "import/consistent-type-specifier-style": "off",
        "import/exports-last": "off",
        "import/prefer-default-export": "off",
        "max-lines-per-function": "off",
        "no-ternary": "off",
        "unicorn/no-null": "off"
      }
    },
    {
      "files": [
        "example/nextjs-ai-x402-exa/app/layout.tsx",
        "example/nextjs-ai-x402-base-sepolia-paid-content/app/layout.tsx",
        "example/nextjs-mastra-x402-exa/app/layout.tsx",
        "example/tanstack-start-ai-x402-exa/src/routes/__root.tsx",
        "example/tanstack-start-mastra-x402-exa/src/routes/__root.tsx"
      ],
      "rules": {
        "import/no-unassigned-import": "off"
      }
    },
    {
      "files": [
        "example/tanstack-start-ai-x402-exa/src/routeTree.gen.ts",
        "example/tanstack-start-mastra-x402-exa/src/routeTree.gen.ts"
      ],
      "rules": {
        "capitalized-comments": "off",
        "import/no-unassigned-import": "off",
        "unicorn/filename-case": "off"
      }
    },
    {
      "files": [
        "example/nextjs-ai-x402-exa/next-env.d.ts",
        "example/nextjs-ai-x402-base-sepolia-paid-content/next-env.d.ts",
        "example/nextjs-mastra-x402-exa/next-env.d.ts"
      ],
      "rules": {
        "capitalized-comments": "off",
        "import/no-unassigned-import": "off"
      }
    },
    {
      "files": ["packages/sdk/src/x402/**/*.ts", "packages/sdk/src/weixin-ai-pay/**/*.ts"],
      "rules": {
        "func-style": "off",
        "import/consistent-type-specifier-style": "off",
        "import/exports-last": "off",
        "import/max-dependencies": "off",
        "import/prefer-default-export": "off",
        "max-lines-per-function": "off",
        "max-params": "off",
        "max-statements": "off",
        "new-cap": "off",
        "no-continue": "off",
        "no-ternary": "off",
        "typescript/consistent-type-definitions": "off",
        "typescript/method-signature-style": "off",
        "unicorn/no-null": "off"
      }
    },
    {
      "files": ["packages/sdk/test/x402/**/*.ts", "packages/sdk/test/weixin-ai-pay/**/*.ts"],
      "rules": {
        "func-style": "off",
        "id-length": "off",
        "max-lines": "off",
        "no-duplicate-imports": "off",
        "require-await": "off"
      }
    }
  ]
}
