{
  "name": "alpha-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace for the Avery SDK and documentation.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "dev": "pnpm --filter @averyso/alpha dev",
    "lint": "oxlint --max-warnings=0",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm --filter @averyso/alpha test:coverage",
    "build:sdk": "pnpm --filter @averyso/alpha build",
    "verify": "pnpm lint && pnpm format:check && pnpm build:sdk && pnpm typecheck && pnpm test:coverage && pnpm build && pnpm pack:check",
    "pack:check": "sh -c 'pnpm --filter @averyso/alpha pack --dry-run; status=$?; rm -f averyso-alpha-*.tgz; exit $status'",
    "docs:dev": "pnpm --filter @averyso/alpha-docs dev",
    "docs:build": "pnpm --filter @averyso/alpha-docs build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm verify && changeset publish --no-git-tag",
    "release:publish": "changeset publish --no-git-tag",
    "release:alpha": "changeset version --snapshot alpha && changeset publish --tag alpha --no-git-tag",
    "lint-staged": "lint-staged",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^24.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.2.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.4.0"
}
